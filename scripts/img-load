#!/usr/bin/env bash
# =============================================================================
# img-load <image-name:tag>
# Loads a pre-seeded OCI image from /data/images into the local Docker daemon.
# Call this at the start of a pipeline before any docker build/run commands.
#
# Example:
#   img-load node:20-alpine
#   img-load python:3.12-slim
# =============================================================================
set -euo pipefail

IMAGE="${1:?Usage: img-load <image:tag>}"
IMAGES_DIR="/data/images"

# Resolve to filesystem-safe name
safe_name="docker.io_library_${IMAGE//\//_}"
safe_name="${safe_name//:/_}"
OCI_PATH="$IMAGES_DIR/$safe_name"

if [[ ! -d "$OCI_PATH" ]]; then
    echo "Image not found in local store: $IMAGE"
    echo "Available images:"
    img-list
    exit 1
fi

echo "Loading $IMAGE from $OCI_PATH into Docker daemon..."
skopeo copy \
    "oci:${OCI_PATH}:latest" \
    "docker-daemon:${IMAGE}"

echo "Done. Image is now available as: $IMAGE"
